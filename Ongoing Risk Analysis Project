import matplotlib.pyplot as plt

def plot_uc_risk_by_period(df, months=3, min_count=0):

	filtered_df = df[
		df["UC_Riskklass_Numerical_Current"].isin([1, 2, 3, 4, 5])
	].copy()

	filtered_df["UC_Riskprognos"] = pd.to_numeric(
		filtered_df["UC_Riskprognos"],
		errors="coerce"
	)

	filtered_df["Estimated_YearMonth_dt"] = pd.to_datetime(
		filtered_df["Estimated_YearMonth"],
		errors="coerce"
	)

	filtered_df = filtered_df.dropna(
		subset=["Estimated_YearMonth_dt", "UC_Riskprognos"]
	).copy()

	base_date = filtered_df["Estimated_YearMonth_dt"].min()

	filtered_df["month_index"] = (
		(filtered_df["Estimated_YearMonth_dt"].dt.year - base_date.year) * 12
		+ (filtered_df["Estimated_YearMonth_dt"].dt.month - base_date.month)
	)

	filtered_df["period_bucket"] = filtered_df["month_index"] // months

	agg_df = (
		filtered_df
		.groupby("period_bucket")
		.agg(
			UC_Riskprognos_mean=("UC_Riskprognos", "mean"),
			count=("UC_Riskprognos", "size")
		)
		.reset_index()
		.sort_values("period_bucket")
	)

	# Always 12 months total
	months_in_year = 12
	
	# Which month this bucket represents (1–12)
	agg_df["month_num"] = (agg_df["period_bucket"] * months) % months_in_year + 1
	
	# Year offset (only matters if you want 2016, 2017, etc)
	agg_df["year_offset"] = (agg_df["period_bucket"] * months) // months_in_year
	
	# Final label
	agg_df["Period_Label"] = (
		(base_date.year + agg_df["year_offset"]).astype(str)
		+ "-"
		+ agg_df["month_num"].astype(int).astype(str).str.zfill(2)
	)

	if min_count > 0:
		agg_df = agg_df[agg_df["count"] >= min_count]

	plt.figure()

	plt.plot(
		agg_df["Period_Label"],
		agg_df["UC_Riskprognos_mean"]
	)

	# Show x-label only at the first period of each 12-month cycle
	tick_positions = agg_df.index[agg_df["month_num"] == 1]
	tick_labels = agg_df.loc[agg_df["month_num"] == 1, "Period_Label"]

	plt.xticks(ticks=tick_positions, labels=tick_labels, rotation=45)
	plt.ylim(bottom=0)

	plt.xlabel("Company founding year.")
	plt.ylabel("Avg UC Risk Prognos")
	plt.title(f"UC Risk Prognos by {months}-Month Buckets")

	plt.grid(True)

	plt.show()

	return agg_df

