def compute_risk_share_by_industry(
	df,
	allowed_classes=None,
	normalize_within_filter=True,
	sort_col=None,
	group_col='Ind_Category'
):
	
	# Sanitize allowed classes
	if allowed_classes:
		allowed_classes = [
			c for c in allowed_classes
			if str(c) in {'1', '2', '3', '4', '5', 'Non-Numeric'}
		]
	else:
		allowed_classes = None

	analysis_df = df.copy()

	if allowed_classes is not None:
		analysis_df = analysis_df[
			analysis_df['UC_Riskklass_Grouped'].isin(allowed_classes)
		].copy()

	# Total per group
	full_counts = (
		analysis_df
		.groupby(group_col)
		.size()
		.reset_index(name='Total')
	)

	# Risk distribution
	risk_share = (
		analysis_df
		.groupby([group_col, 'UC_Riskklass_Grouped'])
		.size()
		.reset_index(name='Count')
	)

	risk_share = risk_share.merge(full_counts, on=group_col, how='left')

	# Denominator
	if normalize_within_filter:
		denom = risk_share.groupby(group_col)['Count'].transform('sum')
	else:
		denom = risk_share['Total']

	risk_share['Pct'] = risk_share['Count'] / denom * 100

	# Pivot ONLY percentages
	risk_share_wide = (
		risk_share
		.pivot(index=group_col, columns='UC_Riskklass_Grouped', values='Pct')
		.fillna(0)
		.round(1)
		.reset_index()
	)

	# Sort logic
	if sort_col is None:
		available_cols = set(risk_share_wide.columns)
	
		# extract numeric risk columns that actually exist in the result
		numeric_cols = [
			col for col in available_cols
			if str(col).isdigit()
		]
	
		if numeric_cols:
			# pick lowest numeric risk class present
			sort_col = str(min(map(int, numeric_cols)))
		else:
			# fallback if only Non-Numeric exists
			sort_col = 'Non-Numeric'

	if sort_col not in risk_share_wide.columns:
		sort_col = risk_share_wide.columns[1]

	risk_share_wide = risk_share_wide.sort_values(sort_col, ascending=False)

	# Add totals only
	risk_share_wide = risk_share_wide.merge(full_counts, on=group_col, how='left')

	# Rounding totals
	risk_share_wide['Total'] = risk_share_wide['Total'].apply(
		lambda x: x if pd.isna(x)
		else int(x) if x < 1000
		else round(x, -2) if x >= 10000
		else round(x, -1)
	)

	return risk_share_wide

