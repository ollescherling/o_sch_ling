"""
Downloadng SNI codes to properly convert the ones with SNI into readable industries. 
The function above imports the SNI code Excel file, deletes the top row, set the second row
as column names, strips whitespace, selects relevant columns, renames them to SNI and Bransch,
ads SNI to each numerical row, and last returns the dictionary and a unified data frame with 
all of them sorted.
"""

def clean_sni_sheets(sni_dict):
	cleaned = {}

	for sheet_name, df in sni_dict.items():

		# Step 1: drop first row
		df = df.iloc[1:].copy()

		# Step 2: set header
		df.columns = df.iloc[0]

		# Step 3: remove header row from data
		df = df.iloc[1:].reset_index(drop=True)

		# Step 4: strip whitespace
		df.columns = df.columns.astype(str).str.strip()

		# Step 5: select relevant columns per sheet type
		if 'Avdelning' in df.columns:
			df = df[['Avdelning', 'Benämning']]
		elif 'Huvudgrupp' in df.columns:
			df = df[['Huvudgrupp', 'Benämning']]
		elif 'Grupp' in df.columns:
			df = df[['Grupp', 'Benämning']]
		elif 'Undergrupp' in df.columns:
			df = df[['Undergrupp', 'Benämning']]
		elif 'Detaljgrupp' in df.columns:
			df = df[['Detaljgrupp', 'Benämning']]

		# Step 6: rename final output columns
		df.columns = ['SNI', 'Bransch']

		cleaned[sheet_name] = df

	# Step 7: merge all sheets into one dataframe
	all_df = pd.concat(cleaned.values(), ignore_index=True)

	# Ensure string type
	all_df['SNI'] = all_df['SNI'].astype(str)

	# Add SNI prefix (avoid double prefix if already exists)
	all_df['SNI'] = all_df['SNI'].where(
		all_df['SNI'].str.startswith('SNI'),
		'SNI' + all_df['SNI']
	)

	# Step 8: sort by SNI "depth" (shorter = higher level like Avdelning)
	all_df = all_df.assign(_len=all_df['SNI'].str.len())
	all_df = all_df.sort_values('_len').drop(columns='_len').reset_index(drop=True)

	return cleaned, all_df

