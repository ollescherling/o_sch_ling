def filter_blocks(data_frame):
	
	# =========================
	# 1. PREP ORGNR COMPONENTS
	# =========================
	orgnrs_blocks = data_frame['ORGANISATIONSNR'].astype(str).str.strip()
	
	orgnrs_blocks_prefix2 = pd.to_numeric(
		orgnrs_blocks.str[:2], errors='coerce'
	).astype('Int64')
	
	orgnrs_blocks_prefix3 = pd.to_numeric(
		orgnrs_blocks.str[:3], errors='coerce'
	).astype('Int64')
	
	third_fourth_digits_blocks = pd.to_numeric(
		orgnrs_blocks.str[2:4], errors='coerce'
	).astype('Int64')
	
	
	# =========================
	# 2. BUILD MASK
	# =========================
	kommun_region_mask_blocks = (
		orgnrs_blocks.notna() &
		(orgnrs_blocks.str.len() == 10) &
		(
			((orgnrs_blocks_prefix2 >= 20) & (orgnrs_blocks_prefix2 <= 26)) |
			((orgnrs_blocks_prefix3 >= 501) & (orgnrs_blocks_prefix3 <= 519))
		) &
		(third_fourth_digits_blocks > 12)
	)
	
	
	# =========================
	# 3. NAME FILTER
	# =========================
	name_filter = data_frame['PARTNER_ID'].str.contains(
		r"STATOIL|\bCIRCLE\b|CIRCLEK|\bINGO\b|\bKOMMUN\b|REGION|MYNDIGHET|BANK|\bSEB\b|\bOY\b",
		case=False,
		na=False
	)
	
	
	# =========================
	# 4. OTHER FILTERS
	# =========================
	invalid_orgnr_filter = (
		data_frame['ORGANISATIONSNR'].isna() |
		data_frame['ORGANISATIONSNR'].isin([
			'5560006834',
			'0000000000',
			''
		])
	)
	
	starts_with_filter = data_frame['PARTNER_ID'].str.startswith('..')
	
	# =========================
	# 5. COMBINE FILTERS
	# =========================
	exclusion_mask = (
		name_filter |
		starts_with_filter |
		invalid_orgnr_filter |
		kommun_region_mask_blocks
	)
	
	
	# =========================
	# 6. SPLIT DATAFRAMES
	# =========================
	inclusion_rows_df = data_frame[~exclusion_mask].copy()
	exclusion_rows_df = data_frame[exclusion_mask].copy()
	
	# =========================
	# 7. RETURN
	# =========================
	return inclusion_rows_df, exclusion_rows_df

