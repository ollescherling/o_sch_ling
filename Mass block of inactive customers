" Function for clearing trailing spaces and unnecessary .0 decimals. "

def strip_all_columns(df):
	for col in df.columns:
		if df[col].dtype == "object":
			df[col] = (
				df[col]
				.astype(str)
				.str.replace(".0", "", regex=False)
				.str.replace(" 00:00:00", "", regex=False)
				.str.strip()
			)
	return df

