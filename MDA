import sklearn
from sklearn.discriminant_analysis import LinearDiscriminantAnalysis
from sklearn.model_selection import train_test_split
from IPython.display import display

"""
Input variables for the discriminant.
Working capital
Retained earnings
Earnings before interest and taxes
Sales
Total assets
Market value equity
Book value of total debt

X1 = Working capital / Total assets
X2 = Retained earnings / Total assets
X3 = Earnings before interest and taxes / Total assets
X4 = Market value equity / Book value of total debt
X5 = Sales / Total assets

Z = (V1X1 + V2X2 + V3X3 + V4X4 + V5X5) = 
    (V1*Working capital/Total assets + V2*Retained earnings/Total assets + V3*Earnings before interest and taxes/Total Assets +
     V4*Market value equity/Book value of total debt + V5*Sales/Total assets)
	
Working Capital	- Current assets minus current liabilities.
Retained Earnings - Cumulative profits kept in the business rather than paid as dividends.
EBIT - Operating profit before interest and taxes.
Market Value Equity	- Market value of shareholders' ownership in the firm.
Book Value Total Debt - Total liabilities recorded on the balance sheet.
Sales - Revenue generated from operations.
Total Assets - Total economic resources owned by the company.
"""

" Creation of the data frame of 33 bankruptcies and 33 non-bankruptcies. "

def dataframe_creator(
	num_companies,
	working_capital_range,
	retained_earnings_range,
	ebit_range,
	sales_range,
	market_value_equity_range,
	book_value_total_debt_range,
	iterations=1,
	bankrupt=False,
	instability_non_bankrupt=0.05,
	instability_bankrupt=0.2,
	non_bankrupt_drift=-0.05,
	bankrupt_drift=-0.2,
	mean=15, # Mean e value.
	sigma=1.4, # Default skew when skewed.
	skewed=False
):
	all_years = {}

	for year in range(1, iterations + 1):

		# Generate the first year normally.
		if year == 1:

			df = pd.DataFrame()

			df["Total_assets"] = np.random.lognormal(
				mean=mean,
				sigma=sigma,
				size=num_companies
			).astype(int)

			# If skewed, bankrupt companies.
			if skewed:
				df["Working_capital"] = (df["Total_assets"] * np.random.triangular(working_capital_range[0], working_capital_range[0] + (working_capital_range[1] - working_capital_range[0]) * 0.35, working_capital_range[1], num_companies)).astype(int)
				df["Retained_earnings"] = (df["Total_assets"] * np.random.triangular(retained_earnings_range[0], retained_earnings_range[0] + (retained_earnings_range[1] - retained_earnings_range[0]) * 0.35, retained_earnings_range[1], num_companies)).astype(int)
				df["EBIT"] = (df["Total_assets"] * np.random.triangular(ebit_range[0], ebit_range[0] + (ebit_range[1] - ebit_range[0]) * 0.35, ebit_range[1], num_companies)).astype(int)
				df["Sales"] = (df["Total_assets"] * np.random.triangular(sales_range[0], sales_range[0] + (sales_range[1] - sales_range[0]) * 0.35, sales_range[1], num_companies)).astype(int)
				df["Market_value_equity"] = (df["Total_assets"] * np.random.triangular(market_value_equity_range[0], market_value_equity_range[0] + (market_value_equity_range[1] - market_value_equity_range[0]) * 0.35, market_value_equity_range[1], num_companies)).astype(int)
				df["Book_value_total_debt"] = (df["Total_assets"] * np.random.triangular(book_value_total_debt_range[0], book_value_total_debt_range[0] + (book_value_total_debt_range[1] - book_value_total_debt_range[0]) * 0.65, book_value_total_debt_range[1], num_companies)).astype(int)

			# Else, non-bankrupt companies.
			else:
				df["Working_capital"] = (df["Total_assets"] * np.random.uniform(*working_capital_range, num_companies)).astype(int)
				df["Retained_earnings"] = (df["Total_assets"] * np.random.uniform(*retained_earnings_range, num_companies)).astype(int)
				df["EBIT"] = (df["Total_assets"] * np.random.uniform(*ebit_range, num_companies)).astype(int)
				df["Sales"] = (df["Total_assets"] * np.random.uniform(*sales_range, num_companies)).astype(int)
				df["Market_value_equity"] = (df["Total_assets"] * np.random.uniform(*market_value_equity_range, num_companies)).astype(int)
				df["Book_value_total_debt"] = (df["Total_assets"] * np.random.uniform(*book_value_total_debt_range, num_companies)).astype(int)

		# Subsequent years drift from the previous year.
		else:

			df = all_years[year - 1].copy()

			if skewed:
				instability = instability_bankrupt
				drift = bankrupt_drift
			else:
				instability = instability_non_bankrupt
				drift = non_bankrupt_drift

			for column in [
				"Total_assets",
				"Working_capital",
				"Retained_earnings",
				"EBIT",
				"Sales",
				"Market_value_equity",
				"Book_value_total_debt"
			]:

				shock = np.random.normal(
					loc=drift,
					scale=instability,
					size=num_companies
				)

				df[column] = (
					df[column]
					*
					(1 + shock)
				).astype(int)

		# Prevent denominator values from becoming zero or negative.
		df["Total_assets"] = np.maximum(
			1,
			df["Total_assets"]
		)

		df["Book_value_total_debt"] = np.maximum(
			1,
			df["Book_value_total_debt"]
		)

		df["Bankruptcy"] = int(bankrupt)

		all_years[year] = df

	if iterations == 1:
		return all_years[1]

	return all_years

# Non-bankrupt companies.
non_bankrupt_dict = dataframe_creator(
	num_companies=10000, # Sample size.
	working_capital_range=(-0.2, 0.5),
	retained_earnings_range=(-0.3, 1.0),
	ebit_range=(-0.05, 0.2),
