"""
Input variables for the discriminants.
Working capital
Retained earnings
Earnings before interest and taxes
Sales
Total assets
Market value equity
Book value of total debt

X1 = Working capital / Total assets
X2 = Retained earnings / Total assets
X3 = Earnings before interest and taxes / Total assets
X4 = Market value equity / Book value of total debt
X5 = Sales / Total assets

Z = (V1X1 + V2X2 + V3X3 + V4X4 + V5X5) = 
    (V1*Working capital/Total assets + V2*Retained earnings/Total assets + V3*Earnings before interest and taxes/Total Assets +
     V4*Market value equity/Book value of total debt + V5*Sales/Total assets)
	
Working Capital	- Current assets minus current liabilities.
Retained Earnings - Cumulative profits kept in the business rather than paid as dividends.
EBIT - Operating profit before interest and taxes.
Market Value Equity	- Market value of shareholders' ownership in the firm.
Book Value Total Debt - Total liabilities recorded on the balance sheet.
Sales - Revenue generated from operations.
Total Assets - Total economic resources owned by the company.
"""

" Creation of the data frame of bankruptcies and non-bankruptcies. "
def dataframe_creator(
	num_companies,
	working_capital_range,
	retained_earnings_range,
	ebit_range,
	sales_range,
	market_value_equity_range,
	book_value_total_debt_range,
	iterations=1,
	bankrupt=False,
	base_convergence=0.05,
	base_randomness=0.5,
	mean=15,
	sigma=1.4
):
	all_years = {}

	for year in range(1, iterations + 1):

		# Generate Year 1.
		if year == 1:

			df = pd.DataFrame()

			df["Total_assets"] = np.random.lognormal(
				mean=mean,
				sigma=sigma,
				size=num_companies
			).astype(int)
			# Triangular left, mode, right, and data frame size by ratio creation.
			if bankrupt:
				
				df["WC_factor"] = np.random.triangular(
					working_capital_range[0],
					working_capital_range[0] + (working_capital_range[1] - working_capital_range[0]) * 0.35,
					working_capital_range[1],
					num_companies
				)

				df["RE_factor"] = np.random.triangular(
					retained_earnings_range[0],
					retained_earnings_range[0] + (retained_earnings_range[1] - retained_earnings_range[0]) * 0.35,
					retained_earnings_range[1],
					num_companies
				)

				df["EBIT_factor"] = np.random.triangular(
					ebit_range[0],
					ebit_range[0] + (ebit_range[1] - ebit_range[0]) * 0.35,
					ebit_range[1],
					num_companies
				)

				df["Sales_factor"] = np.random.triangular(
					sales_range[0],
					sales_range[0] + (sales_range[1] - sales_range[0]) * 0.35,
					sales_range[1],
					num_companies
				)

				df["MVE_factor"] = np.random.triangular(
					market_value_equity_range[0],
					market_value_equity_range[0] + (market_value_equity_range[1] - market_value_equity_range[0]) * 0.35,
					market_value_equity_range[1],
					num_companies
				)

				df["Debt_factor"] = np.random.triangular(
					book_value_total_debt_range[0],
					book_value_total_debt_range[0] + (book_value_total_debt_range[1] - book_value_total_debt_range[0]) * 0.65,
					book_value_total_debt_range[1],
					num_companies
				)

			else:

				df["WC_factor"] = np.random.uniform(
					working_capital_range[0],
					working_capital_range[1],
					num_companies
				)

				df["RE_factor"] = np.random.uniform(
					retained_earnings_range[0],
					retained_earnings_range[1],
					num_companies
				)

				df["EBIT_factor"] = np.random.uniform(
					ebit_range[0],
					ebit_range[1],
					num_companies
				)

				df["Sales_factor"] = np.random.uniform(
					sales_range[0],
					sales_range[1],
					num_companies
				)

				df["MVE_factor"] = np.random.uniform(
					market_value_equity_range[0],
					market_value_equity_range[1],
					num_companies
				)

				df["Debt_factor"] = np.random.uniform(
					book_value_total_debt_range[0],
					book_value_total_debt_range[1],
					num_companies
				)

		# Earlier years.
		else:

			df = all_years[year - 1].copy()

			convergence = base_convergence * (year - 1)
			randomness = base_randomness * (year - 1)

			if bankrupt:

				healthy_targets = {
					"WC_factor": 0.15,
					"RE_factor": 0.25,
					"EBIT_factor": 0.08,
					"Sales_factor": 1.20,
					"MVE_factor": 1.50,
					"Debt_factor": 0.80
				}

				for ratio in healthy_targets:

					df[ratio] = (
						df[ratio]
						+
						convergence
						*
						(
							healthy_targets[ratio]
							-
							df[ratio]
						)
						+
						np.random.normal(
							0,
							randomness,
							num_companies
						)
					)

			else:

				for ratio in [
					"WC_factor",
					"RE_factor",
					"EBIT_factor",
					"Sales_factor",
					"MVE_factor",
					"Debt_factor"
				]:

					df[ratio] = (
						df[ratio]
						+
						np.random.normal(
							0,
							randomness / 2,
							num_companies
						)
					)

			df["Total_assets"] = (
				df["Total_assets"]
				*
				np.random.uniform(
					0.97,
					1.03,
					num_companies
				)
			).astype(int)

		df["Total_assets"] = np.maximum(
			1,
			df["Total_assets"]
		)

		df["Book_value_total_debt"] = np.maximum(
			1,
			(df["Total_assets"] * df["Debt_factor"]).astype(int)
		)

		df["Working_capital"] = (
			df["Total_assets"]
			*
			df["WC_factor"]
		).astype(int)

		df["Retained_earnings"] = (
			df["Total_assets"]
			*
			df["RE_factor"]
		).astype(int)

		df["EBIT"] = (
			df["Total_assets"]
			*
			df["EBIT_factor"]
		).astype(int)

		df["Sales"] = (
			df["Total_assets"]
			*
			df["Sales_factor"]
		).astype(int)

		df["Market_value_equity"] = (
			df["Book_value_total_debt"]
			*
			df["MVE_factor"]
		).astype(int)

		df["Bankruptcy"] = int(not bankrupt)

		all_years[year] = df
	# Return at once if only one year.
	if iterations == 1:
		return all_years[1]

	return all_years

# Non-bankrupt companies.
non_bankrupt_dict = dataframe_creator(
	num_companies=100,
	working_capital_range=(-0.2, 0.5),
