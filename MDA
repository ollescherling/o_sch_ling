	market_value_equity_range=(0.2, 4.0),
	book_value_total_debt_range=(0.2, 1.5),
	skewed=False,
	iterations = 5,
	bankrupt = False
	
)

# Bankrupt companies.
bankrupt_dict = dataframe_creator(
	num_companies=10000, # Sample size.
	working_capital_range=(-0.5, 0.3),
	retained_earnings_range=(-1.0, 0.5),
	ebit_range=(-0.2, 0.1),
	# The parameters below are always non-negative.
	sales_range=(0.1, 2.0), # Sales are non-negative.
	market_value_equity_range=(0.05, 2.0),
	book_value_total_debt_range=(0.3, 2.5),
	skewed=True,
	iterations = 5,
	bankrupt = True
)

# Appending bankrutpcies and non-bankrutpcies into the Multiple Discriminant Analysis (MDA) dictionary with each iteration.
mda_dict = {}
for year in bankrupt_dict.keys():

	mda_dict[year] = pd.concat([
		bankrupt_dict[year],
		non_bankrupt_dict[year]
	]).reset_index(drop=True)

def ratio_creator_and_f_tests(mda_dict):

	ratio_dict = {}
	f_test_dict = {}

	for year, mda_df in mda_dict.items():

		mda_df = mda_df.copy()

		# Creating the variable means for each ratio.
		mda_df["WC/TA"] = (mda_df["Working_capital"] / mda_df["Total_assets"]).round(3)
		mda_df["RE/TA"] = (mda_df["Retained_earnings"] / mda_df["Total_assets"]).round(3)
		mda_df["EBIT/TA"] = (mda_df["EBIT"] / mda_df["Total_assets"]).round(3)
		mda_df["MVE/BVTB"] = (mda_df["Market_value_equity"] / mda_df["Book_value_total_debt"]).round(3)
		mda_df["S/TA"] = (mda_df["Sales"] / mda_df["Total_assets"]).round(3)

		t_test_results = []

		for variable in ["WC/TA","RE/TA","EBIT/TA","MVE/BVTB","S/TA"]:

			t_stat, p_value = ttest_ind(
				mda_df.loc[mda_df["Bankruptcy"] == 0, variable],
				mda_df.loc[mda_df["Bankruptcy"] == 1, variable],
				equal_var=False
			)

			F_stat = t_stat ** 2

			t_test_results.append({
				"Variable": variable,
				"F-statistic": round(F_stat, 1),
				"P-value": f"{p_value:.2e}"
			})

		ratio_dict[year] = mda_df
		f_test_dict[year] = pd.DataFrame(t_test_results)

	return ratio_dict, f_test_dict

# The t-values scale a lot with the number of observations as the p-values collapse 
# when data sets differ more with more observations. Though, this is not an issue in MDA.
