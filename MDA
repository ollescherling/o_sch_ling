""" 
Running test runs. The output above is trained on the same data, which can give too lower error percentages. 
These test runs do not reflect reality as you are testing a sample of the perfect training data set.
"""

def test_data_mda_analysis_dict(
	ratio_dict,
	test_size=0.4
):
	results_dict = {}

	for year, mda_df in ratio_dict.items():

		# Defining independent variables in X.
		X = mda_df[["WC/TA","RE/TA","EBIT/TA","MVE/BVTB","S/TA"]]

		# Defining the dependent variable as y.
		y = mda_df["Bankruptcy"]

		# Creating training and test samples.
		X_train, X_test, y_train, y_test = train_test_split(
			X,
			y,
			test_size=test_size,
			stratify=y
		)

		# Fitting the model on the training data.
		lda = LinearDiscriminantAnalysis()
		lda.fit(X_train, y_train)

		# Predicting on the unseen test data.
		predictions_test = lda.predict(X_test)

		confusion_test_df = pd.crosstab(
			y_test,
			predictions_test,
			rownames=["Actual"],
			colnames=["Predicted"]
		)
		
		# Saftey measure if any of the values become zero.
		confusion_test_df = confusion_test_df.reindex(
			index=[0, 1],
			columns=[0, 1],
			fill_value=0
		)

		confusion_test_df.index = [
			"Actual Bankrupt",
			"Actual Non-bankrupt"
		]
		
		confusion_test_df.columns = [
			"Predicted Bankrupt",
			"Predicted Non-bankrupt"
		]

		results_dict[year] = {
			"lda": lda,
			"confusion_test_df": confusion_test_df
		}

	return results_dict

test_results = test_data_mda_analysis_dict(ratio_dict)

def print_confusion_percentages(
	results_dict,
	test_results
):
	for year in range(1, len(results_dict) + 1):

		print(f"\nTRAINING MATRIX - YEAR {year}")

		training_df = results_dict[year]["confusion_training_df"]

		training_pct_df = (
			training_df.div(training_df.sum(axis=1), axis=0) * 100
		).round(2)

		print(training_pct_df)

		print(f"\nTEST MATRIX - YEAR {year}")

		test_df = test_results[year]["confusion_test_df"]

		test_pct_df = (
			test_df.div(test_df.sum(axis=1), axis=0) * 100
		).round(2)

		print(test_pct_df)

		print("\n")

print_confusion_percentages(results_dict,test_results)

" Monte carlo simulation while running the test set an arbitrary number of times. "

def monte_carlo_mda_dict(
	num_runs=20,
	test_size=0.1
):
	results_dict = {
		1: [],
		2: [],
		3: [],
		4: [],
		5: []
	}

	for run in range(num_runs):

		# Non-bankrupt companies.
		non_bankrupt_dict = dataframe_creator(
			num_companies=10000,
			working_capital_range=(-0.2, 0.5),
			retained_earnings_range=(-0.3, 1.0),
			ebit_range=(-0.05, 0.2),
			sales_range=(0.3, 3.0),
			market_value_equity_range=(0.2, 4.0),
			book_value_total_debt_range=(0.2, 1.5),
			iterations=5,
			bankrupt=False
		)

		# Bankrupt companies.
		bankrupt_dict = dataframe_creator(
			num_companies=10000,
			working_capital_range=(-0.5, 0.3),
			retained_earnings_range=(-1.0, 0.5),
			ebit_range=(-0.2, 0.1),
			sales_range=(0.1, 2.0),
			market_value_equity_range=(0.05, 2.0),
			book_value_total_debt_range=(0.3, 2.5),
			iterations=5,
			bankrupt=True
		)

		mda_dict = {}

		for year in range(1, 6):

			mda_dict[year] = pd.concat(
				[
					bankrupt_dict[year],
					non_bankrupt_dict[year]
				]
			).reset_index(drop=True)

		ratio_dict, _ = ratio_creator_and_f_tests(
			mda_dict
		)

		test_results_dict = test_data_mda_analysis_dict(
			ratio_dict,
			test_size=test_size
		)

		for year, year_results in test_results_dict.items():

			confusion_test_df = year_results[
				"confusion_test_df"
			]

			TP = confusion_test_df.iloc[0, 0]
			FN = confusion_test_df.iloc[0, 1]
			FP = confusion_test_df.iloc[1, 0]
			TN = confusion_test_df.iloc[1, 1]

			type_1_error = FN / (FN + TP)
			type_2_error = FP / (FP + TN)
			accuracy = (TP + TN) / (TP + TN + FP + FN)

			results_dict[year].append({
				"Run": run + 1,
				"Type_1_Error": type_1_error,
				"Type_2_Error": type_2_error,
				"Accuracy": accuracy
			})

	for year in results_dict:

		results_dict[year] = pd.DataFrame(
			results_dict[year]
		)

	return results_dict


mc_results_dict = monte_carlo_mda_dict(num_runs=20)

mc_results_dict[1]
mc_results_dict[5]

def training_vs_monte_carlo_results(
	results_dict,
	mc_results_dict
):
	for iteration in results_dict:

		confusion_training_df = results_dict[iteration]["confusion_training_df"]
		mc_results_df = mc_results_dict[iteration]

		TP, FN = confusion_training_df.iloc[0]
		FP, TN = confusion_training_df.iloc[1]

		results_df = pd.DataFrame({
			"Training Data": [
				FN / (FN + TP),
				FP / (FP + TN),
				(TP + TN) / (TP + TN + FP + FN)
			],
			"Mean MC": [
				round(mc_results_df["Type_1_Error"].mean(), 4),
				round(mc_results_df["Type_2_Error"].mean(), 4),
				round(mc_results_df["Accuracy"].mean(), 4)
			],
			"Std MC": [
				round(mc_results_df["Type_1_Error"].std(), 4),
				round(mc_results_df["Type_2_Error"].std(), 4),
				round(mc_results_df["Accuracy"].std(), 4)
			]
		},
		index=[
			"Type I Error",
			"Type II Error",
			"Accuracy"
		])

		print(f"\n\nYEAR {iteration}")
		display(results_df)

training_vs_monte_carlo_results(
	results_dict,
	mc_results_dict
)
		
def plot_z_score_distribution(
	ratio_dict,
	year=1
):
	df = ratio_dict[year]

	bankrupt_z = df.loc[df["Bankruptcy"] == 0, "Z"]
	non_bankrupt_z = df.loc[df["Bankruptcy"] == 1, "Z"]

	gray_left = np.percentile(bankrupt_z, 95)
	gray_right = np.percentile(non_bankrupt_z, 5)

	plt.figure(figsize=(12, 5))

	plt.scatter(non_bankrupt_z, np.zeros(len(non_bankrupt_z)), label="Non-bankrupt")
	plt.scatter(bankrupt_z, np.ones(len(bankrupt_z)), label="Bankrupt")

	plt.axvline(0, linestyle="--", label="Cutoff")
	plt.axvspan(
		gray_left,
		gray_right,
		alpha=0.2,
		label=f"Gray Zone ({gray_left:.2f}, {gray_right:.2f})"
	)

	plt.yticks([0, 1], ["Non-bankrupt", "Bankrupt"])
	plt.xlabel("Z-score")
	plt.title(f"Year {year}  |  Gray Zone: {gray_left:.2f} to {gray_right:.2f}")
	plt.legend()
	plt.show()

	print(f"Gray zone: {gray_left:.2f} <= Z <= {gray_right:.2f}")
	
plot_z_score_distribution(
	ratio_dict,
	year=1
)















