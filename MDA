ratio_creator_and_f_tests(mda_dict)[0]

" Creating the discriminant analysis. "

def training_data_mda_analysis(mda_df):
	"""Run MDA and evaluate performance on the same data used for training."""

	# Defining independent variables in X.
	X = mda_df[["WC/TA","RE/TA","EBIT/TA","MVE/BVTB","S/TA"]]

	# Defining the dependent variable as y.
	y = mda_df["Bankruptcy"]

	# Fitting the model.
	lda = LinearDiscriminantAnalysis()
	lda.fit(X, y)

	# Extracting coefficients from the fitted model.
	coefficients_df = pd.DataFrame({
		"Variable": ["WC/TA","RE/TA","EBIT/TA","MVE/BVTB","S/TA"],
		"Coefficient": lda.coef_[0]
	})

	# Using the coefficients to create a discriminant Z score.
	mda_df["Z"] = lda.decision_function(X)

	# Distribution of Z-values for bankruptcies and non-bankruptcies.
	z_distribution_df = mda_df.groupby("Bankruptcy")["Z"].describe()

	# Predictions on the training data.
	predictions = lda.predict(X)

	confusion_training_df = pd.crosstab(
		y,
		predictions,
		rownames=["Actual"],
		colnames=["Predicted"]
	)

	confusion_training_df.index = [
		"Actual Non-bankrupt",
		"Actual Bankrupt"
	]

	confusion_training_df.columns = [
		"Predicted Non-bankrupt",
		"Predicted Bankrupt"
	]

	return (
		lda,
		coefficients_df,
		z_distribution_df,
		confusion_training_df
	)

def training_data_mda_analysis_dict(mda_dict):

	results_dict = {}

	for year, mda_df in mda_dict.items():
		lda, coefficients_df, z_distribution_df, confusion_training_df = (
			training_data_mda_analysis(mda_df)
		)
		results_dict[year] = {
			"lda": lda,
			"coefficients_df": coefficients_df,
			"z_distribution_df": z_distribution_df,
			"confusion_training_df": confusion_training_df
		}
	return results_dict

# First create the ratios.
ratio_dict, f_test_dict = ratio_creator_and_f_tests(mda_dict)

# Then run the MDA on every year.
results_dict = training_data_mda_analysis_dict(ratio_dict)

